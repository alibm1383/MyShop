@page
@model MyShop.Pages.Admin.EditModel
@{
    ViewData["Title"] = "ویرایش کالا";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg p-4" style="max-width: 500px; width: 100%;">
        <h2 class="text-center mb-4">ویرایش کالا</h2>

        <form method="post" enctype="multipart/form-data">

            <input type="hidden" asp-for="Product.Id"/>

            <div class="mb-3">
                <label asp-for="Product.Name" class="form-label">نام کالا</label>
                <input asp-for="Product.Name" class="form-control" />
                <span asp-validation-for="Product.Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.Description" class="form-label">توضیحات</label>
                <textarea asp-for="Product.Description" class="form-control"></textarea>
                <span asp-validation-for="Product.Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.Price" class="form-label">قیمت</label>
                <input asp-for="Product.Price" type="number" class="form-control" />
                <span asp-validation-for="Product.Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.Quantity" class="form-label">تعداد</label>
                <input asp-for="Product.Quantity" type="number" class="form-control" />
                <span asp-validation-for="Product.Quantity" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Product.Picture" class="form-label">تصویر کالا</label>
                <input asp-for="Product.Picture" type="file" class="form-control" />
                <span asp-validation-for="Product.Picture" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">دسته‌بندی‌ها</label>

                @foreach (var item in Model.Categories)
                {
                    <div class="form-check">
                        <input class="form-check-input"
                        type="checkbox"
                        name="Product.CategoriesId"
                        value="@item.Id"
                        checked = "@(Model.Product.CategoriesId.Contains(item.Id))"
                        id="cat_@item.Id">
                               

                        <label class="form-check-label" for="cat_@item.Id">
                            @item.Title
                        </label>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary w-100">ثبت کالا</button>
        </form>
    </div>
</div>
