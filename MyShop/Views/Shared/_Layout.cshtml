@using System.Security.Claims;
<!DOCTYPE html>
<html lang="fa">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyShop</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyShop.styles.css" asp-append-version="true" />
</head>
<body dir="rtl" style="background-color: #f8f9fa;">

    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand text-primary fw-bold" asp-controller="Home" asp-action="Index">🛒 فروشگاه من</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-between" id="navbarNav">
                    <ul class="navbar-nav">
                       
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="ContactUs">📞 تماس با ما</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-success fw-bold">👤 @User.FindFirst(ClaimTypes.Email)?.Value خوش آمدید</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">🚪 خروج</a>
                            </li>
                            @if (bool.Parse(User.FindFirstValue("IsAdmin")))
                            {
                                <li class="nav-item ms-auto">
                                    <a class="nav-link text-white fw-bold bg-danger px-3 py-2 rounded" asp-page="/Admin/Index">
                                        پنل ادمین
                                    </a>
                                </li>
                            }

                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-primary" asp-controller="Account" asp-action="Register">📝 ثبت نام</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-primary" asp-controller="Account" asp-action="Login">🔑 ورود</a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <main class="container-fluid mt-4">
        <div class="row">
            <aside class="col-md-2">
                @await Component.InvokeAsync("ProductGroupsComponent")
            </aside>
            <section class="col-md-10">
                @RenderBody()
            </section>
        </div>
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-4">
        <div class="container">
             طراحی شده با ❤️ توسط علی
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
