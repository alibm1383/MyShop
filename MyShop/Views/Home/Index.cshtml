@using Models.Models;
@model IEnumerable<Product>
@{
    ViewData["Title"] = "Home Page";
}

<style>
    body {
        font-family: 'Poppins', sans-serif;
        background: #f8f9fa;
        color: #333;
    }

    .product-container {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 30px;
        padding: 30px;
        max-width: 1300px;
        margin: auto;
    }

    .product-card {
        width: 280px;
        background: white;
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease-in-out;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
        }

    .product-image {
        width: 180px;
        height: 180px;
        object-fit: cover;
        margin-bottom: 15px;
        border-radius: 10px;
        transition: transform 0.3s;
    }

    .product-card:hover .product-image {
        transform: scale(1.05);
    }

    .product-title {
        font-weight: 600;
        font-size: 18px;
        margin-bottom: 8px;
        color: #444;
    }

    .product-price {
        font-size: 16px;
        font-weight: bold;
        color: #ff6a00;
        margin-bottom: 10px;
    }

    .btn-custom {
        border-radius: 30px;
        font-size: 15px;
        padding: 10px 20px;
        background: linear-gradient(45deg, #ff6a00, #ee0979);
        color: white;
        border: none;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-custom:hover {
            background: linear-gradient(45deg, #ee0979, #ff6a00);
            transform: scale(1.05);
        }
</style>

<div class="text-center">
    <h1 class="display-4 mb-5" style="color: #333; font-weight: bold;">@ViewBag.Titre</h1>
    <div class="product-container">
        @foreach (var item in Model)
        {
            <div class="product-card">
                <img src="/Images/@(item.Id).jpg?v=@System.IO.File.GetLastWriteTime("wwwroot/images/"+item.Id+".jpg")" class="product-image" />
                <h5 class="product-title">@item.Title</h5>
                <div class="product-price">@item.Price تومان</div>
                <a class="btn-custom" asp-action="Detail" asp-controller="Home" asp-route-id="@item.Id">
                    مشاهده جزئیات
                </a>
            </div>
        }
    </div>
</div>

