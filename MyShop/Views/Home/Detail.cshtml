@using Models.Models
@model DetailsViewModel
@{
    ViewData["Title"] = Model.Product.Title;
}

<div class="container mt-5">
    <div class="card shadow-lg p-4 rounded">
        <div class="row">
            <!-- بخش تصویر محصول -->
            <div class="col-md-5 text-center">
                <img src="/Images/@(Model.Product.Id).jpg" alt="@Model.Product.Title" class="product-img rounded shadow">
            </div>

            <!-- بخش اطلاعات محصول -->
            <div class="col-md-7">
                <h1 class="display-5 text-primary fw-bold">@Model.Product.Title</h1>
                <hr />
                <p class="py-3 lead text-muted">@Model.Product.Description</p>

                <h4 class="text-danger fw-bold">💰 قیمت: @Model.Product.Price تومان</h4>

                
                <!-- دسته‌بندی‌های محصول -->
                <div class="mt-3">
                    <h5 class="text-dark fw-bold">📂 دسته‌بندی‌ها:</h5>
                    <ul class="list-group list-group-flush">
                        @foreach (var item in Model.Categories)
                        {
                            <li class="list-group-item bg-transparent border-0">
                                <strong class="text-secondary">@item.Title</strong>
                                
                            </li>
                        }
                    </ul>
                </div>

                <!-- دکمه خرید -->
                <div class="mt-4">
                    <a class="btn btn-lg btn-gradient shadow" asp-controller="Home" asp-action="AddToCart" asp-route-productId="@Model.Product.Id">
                        🛒 افزودن به سبد خرید
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- استایل‌های اختصاصی -->
<style>
    body {
        font-family: 'Poppins', sans-serif;
        background: #f8f9fa;
    }

    .card {
        background: white;
        border-radius: 15px;
        transition: all 0.3s;
    }

        .card:hover {
            box-shadow: 0px 10px 30px rgba(0, 0, 0, 0.2);
        }

    .product-img {
        width: 100%;
        max-width: 350px;
        object-fit: cover;
        transition: transform 0.3s ease-in-out;
    }

        .product-img:hover {
            transform: scale(1.05);
        }

    .btn-gradient {
        background: linear-gradient(45deg, #ff6a00, #ee0979);
        color: white;
        padding: 12px 30px;
        border-radius: 30px;
        font-size: 18px;
        font-weight: bold;
        transition: all 0.3s;
        text-decoration: none;
        display: inline-block;
    }

        .btn-gradient:hover {
            background: linear-gradient(45deg, #ee0979, #ff6a00);
            transform: scale(1.05);
        }

    .rating .star {
        font-size: 24px;
        color: #ffcc00;
        margin-right: 2px;
    }

    .rating .text-muted {
        font-size: 16px;
        color: #777;
    }
</style>
